<page title="Secrets">
  <fan ribs="4">
    <rib id="default">
      <open room="keys" why="demo">
        <secret name="apiKey" uses="2">sk_live_fan_demo</secret>
        <observe name="apiKey" why="first-read"/>
        <show expr="apiKey_observed"/>
        <open room="keys" why="seal-data">
          <seal expr="'payload'" key="apiKey_observed" result="sealed"/>
          <show expr="sealed"/>
        </open>
      </open>
    </rib>
  </fan>
</page>
