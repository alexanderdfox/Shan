{
  "name": "shan-lang",
  "displayName": "Shàn Language",
  "description": "Syntax highlighting, formatting, and diagnostics for .shan files",
  "version": "1.0.0",
  "publisher": "peacock",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages", "Formatters", "Linters"],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:shan"
  ],
  "contributes": {
    "languages": [
      {
        "id": "shan",
        "aliases": ["Shàn", "shan"],
        "extensions": [".shan"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "shan",
        "scopeName": "text.xml.shan",
        "path": "./syntaxes/shan.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "shan.run",
        "title": "Shàn: Run File"
      },
      {
        "command": "shan.check",
        "title": "Shàn: Check File"
      },
      {
        "command": "shan.compile",
        "title": "Shàn: Compile to Python"
      }
    ],
    "configuration": {
      "title": "Shàn",
      "properties": {
        "shan.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable for shan CLI"
        },
        "shan.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Peacock project root (folder containing shan/). Empty = auto-detect"
        },
        "shan.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run shan check on save"
        },
        "shan.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run shan fmt on save"
        }
      }
    }
  }
}
